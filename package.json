{
  "name": "nft-bazaar",
  "version": "1.0.0",
  "description": "NFT Marketplace built with Scaffold-ETH 2 + Hardhat 2.22",
  "private": true,
  "workspaces": [
    "packages/hardhat",
    "packages/nextjs"
  ],
  "scripts": {
    "chain": "yarn workspace @se-2/hardhat chain",
    "deploy": "yarn workspace @se-2/hardhat deploy",
    "deploy:sepolia": "yarn workspace @se-2/hardhat deploy:sepolia",
    "test": "yarn workspace @se-2/hardhat test",
    "compile": "yarn workspace @se-2/hardhat compile",
    "clean": "yarn workspace @se-2/hardhat clean",
    "dev": "yarn workspace @se-2/nextjs dev",
    "build": "yarn workspace @se-2/nextjs build",
    "start": "yarn workspace @se-2/nextjs start",
    "lint": "yarn workspace @se-2/nextjs lint",
    "lint:fix": "yarn workspace @se-2/nextjs lint:fix",
    "format": "yarn workspace @se-2/nextjs format"
  },
  "packageManager": "yarn@4.5.1",
  "engines": {
    "node": ">=18.17.0"
  }
}
